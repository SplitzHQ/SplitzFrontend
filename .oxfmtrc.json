{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "objectWrap": "preserve",
  "sortImports": {
    "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"]],
    "newlinesBetween": true,
    "internalPattern": ["@/"]
  },
  "sortTailwindcss": {
    "stylesheet": "./src/assets/base.css",
    "functions": ["twJoin", "twMerge"]
  },
  "sortPackageJson": true,
  "ignorePatterns": ["src/backend/**"]
}
